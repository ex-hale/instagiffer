{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Tests",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python3",
            "args": ["-m", "pytest", "test_instagiffer.py", "-v", "--tb=short"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
